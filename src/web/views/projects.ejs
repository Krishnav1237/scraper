<%- include('layout', { body: `

<div class="page-header" style="height: 80px; background: white; border-bottom: 1px solid #E5E7EB; padding: 0 32px; display: flex; align-items: center; justify-content: space-between;">
  <h1 class="page-header-title" style="font-size: 1.5rem; font-weight: 700; color: #111827;">Projects</h1>
  <span style="font-size: 0.875rem; color: #6B7280;">${projects.length} project${projects.length !== 1 ? 's' : ''}</span>
</div>

<div style="padding: 32px;">

  ${error ? `<div style="margin-bottom: 20px; padding: 12px 16px; background: #FEF2F2; border: 1px solid #FECACA; border-radius: 8px; color: #B91C1C; font-size: 0.875rem;">${error}</div>` : ''}
  ${success ? `<div style="margin-bottom: 20px; padding: 12px 16px; background: #F0FDF4; border: 1px solid #BBF7D0; border-radius: 8px; color: #166534; font-size: 0.875rem;">${success}</div>` : ''}

  <div style="display: grid; grid-template-columns: 1fr 380px; gap: 32px; align-items: start;">

    <!-- Project List -->
    <div>
      ${projects.length === 0 ? `
        <div class="card empty-state">
          <div style="font-size: 40px; margin-bottom: 12px;">📁</div>
          <h3 style="font-size: 1rem; font-weight: 600; color: #111827; margin-bottom: 6px;">No projects yet</h3>
          <p style="color: #6B7280; font-size: 0.875rem;">Create your first project to start monitoring.</p>
        </div>
      ` : `
        <div style="display: flex; flex-direction: column; gap: 12px;">
          ${projects.map(p => `
            <div class="card" style="padding: 20px 24px;">
              <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                  <div style="font-size: 1rem; font-weight: 600; color: #111827;">${p.name}</div>
                  ${p.description ? `<div style="font-size: 0.8rem; color: #6B7280; margin-top: 4px;">${p.description}</div>` : ''}
                  <div style="display: flex; gap: 8px; margin-top: 10px; flex-wrap: wrap;">
                    ${p.playstore_app_id ? `<span class="badge badge-neu" style="font-size: 0.75rem;">Play Store: ${p.playstore_app_id}</span>` : ''}
                    ${p.appstore_app_id ? `<span class="badge badge-neu" style="font-size: 0.75rem;">App Store: ${p.appstore_app_id}</span>` : ''}
                    ${JSON.parse(p.search_terms || '[]').length > 0 ? `<span class="badge badge-pos" style="font-size: 0.75rem;">${JSON.parse(p.search_terms).length} keyword${JSON.parse(p.search_terms).length !== 1 ? 's' : ''}</span>` : ''}
                  </div>
                </div>
                <div style="display: flex; gap: 8px; align-items: center; flex-shrink: 0;">
                  <a href="/projects/${p.id}" class="btn btn-secondary" style="font-size: 0.8rem; padding: 6px 14px; height: auto;">Manage</a>
                  ${p.id !== 1 ? `
                    <form method="POST" action="/projects/${p.id}/delete" onsubmit="return confirm('Delete this project?')">
                      <button type="submit" class="btn btn-secondary" style="font-size: 0.8rem; padding: 6px 14px; height: auto; color: #DC2626; border-color: #FECACA;">Delete</button>
                    </form>
                  ` : ''}
                </div>
              </div>
            </div>
          `).join('')}
        </div>
      `}
    </div>

    <!-- Create Project Form -->
    <div class="card" style="padding: 24px;">
      <h3 style="font-size: 1rem; font-weight: 600; color: #111827; margin-bottom: 20px;">New Project</h3>
      <form method="POST" action="/projects" style="display: flex; flex-direction: column; gap: 16px;">
        <div>
          <label style="font-size: 0.8rem; font-weight: 500; color: #374151; display: block; margin-bottom: 6px;">Project Name <span style="color: #EF4444;">*</span></label>
          <input type="text" name="name" required placeholder="e.g. My App Brand" style="width: 100%; height: 38px; padding: 0 12px; border-radius: 6px; border: 1px solid #D1D5DB; font-size: 0.875rem; background: white; box-sizing: border-box;">
        </div>
        <div>
          <label style="font-size: 0.8rem; font-weight: 500; color: #374151; display: block; margin-bottom: 6px;">Description</label>
          <textarea name="description" placeholder="Optional description" rows="2" style="width: 100%; padding: 8px 12px; border-radius: 6px; border: 1px solid #D1D5DB; font-size: 0.875rem; background: white; resize: vertical; box-sizing: border-box;"></textarea>
        </div>
        <div>
          <label style="font-size: 0.8rem; font-weight: 500; color: #374151; display: block; margin-bottom: 6px;">Search Terms <span style="color: #9CA3AF;">(comma-separated)</span></label>
          <input type="text" name="search_terms" placeholder="e.g. mybrand, mybrand app, mybrand.io" style="width: 100%; height: 38px; padding: 0 12px; border-radius: 6px; border: 1px solid #D1D5DB; font-size: 0.875rem; background: white; box-sizing: border-box;">
        </div>
        <div>
          <label style="font-size: 0.8rem; font-weight: 500; color: #374151; display: block; margin-bottom: 6px;">Required Terms <span style="color: #9CA3AF;">(comma-separated)</span></label>
          <input type="text" name="required_terms" placeholder="e.g. mybrand.io, mybrand.com" style="width: 100%; height: 38px; padding: 0 12px; border-radius: 6px; border: 1px solid #D1D5DB; font-size: 0.875rem; background: white; box-sizing: border-box;">
        </div>
        <div>
          <label style="font-size: 0.8rem; font-weight: 500; color: #374151; display: block; margin-bottom: 6px;">Monitor Subreddits <span style="color: #9CA3AF;">(comma-separated)</span></label>
          <input type="text" name="monitor_subreddits" placeholder="e.g. mybrand, myapp" style="width: 100%; height: 38px; padding: 0 12px; border-radius: 6px; border: 1px solid #D1D5DB; font-size: 0.875rem; background: white; box-sizing: border-box;">
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
          <div>
            <label style="font-size: 0.8rem; font-weight: 500; color: #374151; display: block; margin-bottom: 6px;">Play Store App ID</label>
            <input type="text" name="playstore_app_id" placeholder="com.example.app" style="width: 100%; height: 38px; padding: 0 12px; border-radius: 6px; border: 1px solid #D1D5DB; font-size: 0.875rem; background: white; box-sizing: border-box;">
          </div>
          <div>
            <label style="font-size: 0.8rem; font-weight: 500; color: #374151; display: block; margin-bottom: 6px;">App Store App ID</label>
            <input type="text" name="appstore_app_id" placeholder="1234567890" style="width: 100%; height: 38px; padding: 0 12px; border-radius: 6px; border: 1px solid #D1D5DB; font-size: 0.875rem; background: white; box-sizing: border-box;">
          </div>
        </div>
        <button type="submit" style="height: 40px; background: #2563EB; color: white; border: none; border-radius: 8px; font-size: 0.875rem; font-weight: 600; cursor: pointer;">Create Project</button>
      </form>
    </div>

  </div>
</div>
` }) %>
