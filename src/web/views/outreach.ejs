<%- include('layout', { body: `

<div class="page-header" style="height: 80px; background: white; border-bottom: 1px solid #E5E7EB; padding: 0 32px; display: flex; align-items: center; justify-content: space-between;">
  <h1 class="page-header-title" style="font-size: 1.5rem; font-weight: 700; color: #111827; letter-spacing: -0.01em;">Reddit Outreach</h1>
  <span style="font-size: 0.875rem; color: #6B7280;">${subreddits.length} target${subreddits.length !== 1 ? 's' : ''} &nbsp;·&nbsp; ${drafts.length} draft${drafts.length !== 1 ? 's' : ''}</span>
</div>

<div style="padding: 32px; display: flex; flex-direction: column; gap: 28px;">

  ${error ? `<div style="padding: 12px 16px; background: #FEF2F2; border: 1px solid #FECACA; border-radius: 8px; color: #B91C1C; font-size: 0.875rem;">${error}</div>` : ''}
  ${success ? `<div style="padding: 12px 16px; background: #F0FDF4; border: 1px solid #BBF7D0; border-radius: 8px; color: #166534; font-size: 0.875rem;">${success}</div>` : ''}

  <!-- Connection Status -->
  <div class="card" style="padding: 24px;">
    <h3 style="font-size: 1rem; font-weight: 600; color: #111827; margin-bottom: 16px;">Reddit Account</h3>

    ${!oauthConfigured ? `
      <div style="padding: 16px; background: #FFFBEB; border: 1px solid #FDE68A; border-radius: 8px; font-size: 0.875rem; color: #92400E;">
        <strong>⚠ OAuth not configured.</strong> Set <code>REDDIT_CLIENT_ID</code> and <code>REDDIT_CLIENT_SECRET</code> in your <code>.env</code> file.
        Create a Reddit app at <a href="https://www.reddit.com/prefs/apps" target="_blank" style="color: #2563EB;">reddit.com/prefs/apps</a>
        (type: <em>web app</em>, redirect URI: <code>${typeof config !== 'undefined' ? '' : 'http://localhost:3000/outreach/auth/callback'}</code>).
      </div>
    ` : auth ? `
      <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px;">
        <div style="display: flex; align-items: center; gap: 12px;">
          <span style="display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 50%; background: #ff45001a; font-size: 1.3rem;">🤖</span>
          <div>
            <div style="font-size: 0.9rem; font-weight: 600; color: #111827;">u/${auth.reddit_username || 'unknown'}</div>
            <div style="font-size: 0.75rem; color: #6B7280; margin-top: 2px;">
              Scope: ${auth.scope || 'N/A'} &nbsp;·&nbsp;
              Expires: ${auth.expires_at ? new Date(auth.expires_at).toLocaleString() : 'N/A'}
            </div>
          </div>
          <span style="display: inline-flex; align-items: center; gap: 4px; font-size: 0.75rem; color: #059669; background: #ECFDF5; padding: 4px 10px; border-radius: 20px; border: 1px solid #A7F3D0;">
            ✓ Connected
          </span>
        </div>
        <form method="POST" action="/outreach/auth/disconnect" onsubmit="return confirm('Disconnect Reddit account?')">
          <button type="submit" style="height: 36px; padding: 0 16px; border-radius: 6px; border: 1px solid #FECACA; background: #FEF2F2; color: #DC2626; font-size: 0.8rem; font-weight: 500; cursor: pointer;">Disconnect</button>
        </form>
      </div>
    ` : `
      <div style="display: flex; align-items: center; gap: 16px;">
        <div>
          <div style="font-size: 0.875rem; color: #6B7280;">Not connected. Connect your Reddit account to submit posts.</div>
        </div>
        <a href="/outreach/auth" style="height: 38px; padding: 0 18px; background: #ff4500; color: white; border-radius: 8px; font-size: 0.875rem; font-weight: 600; display: inline-flex; align-items: center; gap: 8px; text-decoration: none; flex-shrink: 0;">
          <span style="font-size: 1rem;">🔗</span> Connect Reddit
        </a>
      </div>
    `}
  </div>

  <!-- Target Subreddits -->
  <div style="display: grid; grid-template-columns: 1fr 340px; gap: 24px; align-items: start;">

    <div class="card" style="padding: 24px;">
      <h3 style="font-size: 1rem; font-weight: 600; color: #111827; margin-bottom: 16px;">Target Subreddits</h3>
      ${subreddits.length === 0 ? `
        <p style="color: #9CA3AF; font-size: 0.875rem;">No subreddits yet. Add one to start targeting.</p>
      ` : `
        <div style="display: flex; flex-direction: column; gap: 8px;">
          ${subreddits.map(s => `
            <div style="display: flex; align-items: center; justify-content: space-between; padding: 12px 16px; background: ${s.enabled ? '#F9FAFB' : '#F3F4F6'}; border: 1px solid ${s.enabled ? '#E5E7EB' : '#D1D5DB'}; border-radius: 8px;">
              <div>
                <div style="font-size: 0.875rem; font-weight: 600; color: ${s.enabled ? '#111827' : '#9CA3AF'};">
                  r/${s.name}
                  ${!s.enabled ? '<span style="font-size: 0.7rem; color: #9CA3AF; margin-left: 6px;">(disabled)</span>' : ''}
                </div>
                <div style="font-size: 0.75rem; color: #6B7280; margin-top: 2px;">
                  Cooldown: ${s.cooldown_hours}h${s.notes ? ' &nbsp;·&nbsp; ' + s.notes : ''}
                </div>
              </div>
              <div style="display: flex; gap: 8px;">
                <form method="POST" action="/outreach/subreddits/${s.id}/toggle">
                  <button type="submit" style="font-size: 0.75rem; padding: 4px 10px; border-radius: 5px; border: 1px solid #D1D5DB; background: white; cursor: pointer; color: ${s.enabled ? '#059669' : '#9CA3AF'};">
                    ${s.enabled ? 'Enabled' : 'Disabled'}
                  </button>
                </form>
                <form method="POST" action="/outreach/subreddits/${s.id}/delete" onsubmit="return confirm('Remove r/${s.name}?')">
                  <button type="submit" style="font-size: 0.75rem; padding: 4px 10px; border-radius: 5px; border: 1px solid #FECACA; background: #FEF2F2; cursor: pointer; color: #DC2626;">Remove</button>
                </form>
              </div>
            </div>
          `).join('')}
        </div>
      `}
    </div>

    <!-- Add Subreddit Form -->
    <div class="card" style="padding: 24px;">
      <h3 style="font-size: 1rem; font-weight: 600; color: #111827; margin-bottom: 16px;">Add Subreddit</h3>
      <form method="POST" action="/outreach/subreddits" style="display: flex; flex-direction: column; gap: 12px;">
        <div>
          <label style="font-size: 0.8rem; font-weight: 500; color: #374151; display: block; margin-bottom: 5px;">Subreddit <span style="color: #EF4444;">*</span></label>
          <input type="text" name="name" required placeholder="e.g. learnprogramming" style="width: 100%; height: 38px; padding: 0 12px; border-radius: 6px; border: 1px solid #D1D5DB; font-size: 0.875rem; box-sizing: border-box;">
          <div style="font-size: 0.73rem; color: #9CA3AF; margin-top: 3px;">Enter without "r/" prefix</div>
        </div>
        <div>
          <label style="font-size: 0.8rem; font-weight: 500; color: #374151; display: block; margin-bottom: 5px;">Cooldown (hours)</label>
          <input type="number" name="cooldown_hours" placeholder="168" value="168" min="1" max="8760" style="width: 100%; height: 38px; padding: 0 12px; border-radius: 6px; border: 1px solid #D1D5DB; font-size: 0.875rem; box-sizing: border-box;">
        </div>
        <div>
          <label style="font-size: 0.8rem; font-weight: 500; color: #374151; display: block; margin-bottom: 5px;">Notes</label>
          <input type="text" name="notes" placeholder="Optional context notes" style="width: 100%; height: 38px; padding: 0 12px; border-radius: 6px; border: 1px solid #D1D5DB; font-size: 0.875rem; box-sizing: border-box;">
        </div>
        <button type="submit" style="height: 38px; background: #2563EB; color: white; border: none; border-radius: 8px; font-size: 0.875rem; font-weight: 600; cursor: pointer;">Add Subreddit</button>
      </form>
    </div>
  </div>

  <!-- Drafts -->
  <div style="display: grid; grid-template-columns: 1fr 380px; gap: 24px; align-items: start;">

    <div class="card" style="padding: 24px;">
      <h3 style="font-size: 1rem; font-weight: 600; color: #111827; margin-bottom: 16px;">Post Drafts</h3>
      ${drafts.length === 0 ? `
        <p style="color: #9CA3AF; font-size: 0.875rem;">No drafts yet. Create a draft post to get started.</p>
      ` : `
        <div style="display: flex; flex-direction: column; gap: 10px;">
          ${drafts.map(d => `
            <div style="padding: 16px; background: #F9FAFB; border: 1px solid #E5E7EB; border-radius: 8px; border-left: 3px solid ${d.status === 'posted' ? '#059669' : d.status === 'failed' ? '#DC2626' : '#2563EB'};">
              <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 12px;">
                <div style="flex: 1; min-width: 0;">
                  <div style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap; margin-bottom: 4px;">
                    <span style="font-size: 0.875rem; font-weight: 600; color: #111827;">${d.title}</span>
                    <span class="badge ${d.status === 'posted' ? 'badge-pos' : d.status === 'failed' ? 'badge-neg' : 'badge-neu'}" style="font-size: 0.7rem;">${d.status}</span>
                    <span class="badge badge-neu" style="font-size: 0.7rem;">${d.kind}</span>
                  </div>
                  <div style="font-size: 0.75rem; color: #6B7280;">
                    r/${d.subreddit_name || '?'}
                    ${d.kind === 'link' && d.url ? ` &nbsp;·&nbsp; <a href="${d.url}" target="_blank" style="color: #2563EB;">${d.url.length > 50 ? d.url.substring(0, 50) + '...' : d.url}</a>` : ''}
                    ${d.kind === 'self' && d.body ? ` &nbsp;·&nbsp; ${d.body.substring(0, 80)}${d.body.length > 80 ? '...' : ''}` : ''}
                  </div>
                  ${d.status === 'posted' && d.reddit_post_url ? `
                    <div style="margin-top: 4px;">
                      <a href="${d.reddit_post_url}" target="_blank" style="font-size: 0.75rem; color: #2563EB; text-decoration: none;">View on Reddit ↗</a>
                    </div>
                  ` : ''}
                  ${d.last_error ? `
                    <div style="margin-top: 4px; font-size: 0.75rem; color: #DC2626;">⚠ ${d.last_error}</div>
                  ` : ''}
                  <div style="font-size: 0.7rem; color: #9CA3AF; margin-top: 4px;">
                    Created ${new Date(d.created_at || '').toLocaleString()}
                    ${d.posted_at ? ' &nbsp;·&nbsp; Posted ' + new Date(d.posted_at).toLocaleString() : ''}
                  </div>
                </div>
                <div style="display: flex; gap: 6px; flex-shrink: 0;">
                  ${d.status !== 'posted' ? `
                    <form method="POST" action="/outreach/drafts/${d.id}/submit" onsubmit="return confirm('Submit this post to r/${d.subreddit_name}?')">
                      <button type="submit" style="font-size: 0.75rem; padding: 5px 12px; border-radius: 5px; border: 1px solid #BBF7D0; background: #ECFDF5; cursor: pointer; color: #059669; white-space: nowrap;" ${!auth ? 'disabled title="Connect Reddit first"' : ''}>
                        ${d.status === 'failed' ? 'Retry' : 'Post'}
                      </button>
                    </form>
                  ` : ''}
                  <form method="POST" action="/outreach/drafts/${d.id}/delete" onsubmit="return confirm('Delete this draft?')">
                    <button type="submit" style="font-size: 0.75rem; padding: 5px 12px; border-radius: 5px; border: 1px solid #FECACA; background: #FEF2F2; cursor: pointer; color: #DC2626;">Delete</button>
                  </form>
                </div>
              </div>
            </div>
          `).join('')}
        </div>
      `}
    </div>

    <!-- Create Draft Form -->
    <div class="card" style="padding: 24px;">
      <h3 style="font-size: 1rem; font-weight: 600; color: #111827; margin-bottom: 16px;">New Draft</h3>
      ${subreddits.length === 0 ? `
        <p style="color: #9CA3AF; font-size: 0.875rem;">Add a target subreddit first.</p>
      ` : `
        <form method="POST" action="/outreach/drafts" style="display: flex; flex-direction: column; gap: 12px;" id="draftForm">
          <div>
            <label style="font-size: 0.8rem; font-weight: 500; color: #374151; display: block; margin-bottom: 5px;">Subreddit <span style="color: #EF4444;">*</span></label>
            <select name="subreddit_id" required style="width: 100%; height: 38px; padding: 0 10px; border-radius: 6px; border: 1px solid #D1D5DB; font-size: 0.875rem; background: white; box-sizing: border-box;">
              ${subreddits.filter(s => s.enabled).map(s => `<option value="${s.id}">r/${s.name}</option>`).join('')}
              ${subreddits.filter(s => !s.enabled).length > 0 ? subreddits.filter(s => !s.enabled).map(s => `<option value="${s.id}" disabled>r/${s.name} (disabled)</option>`).join('') : ''}
            </select>
          </div>
          <div>
            <label style="font-size: 0.8rem; font-weight: 500; color: #374151; display: block; margin-bottom: 5px;">Post Type <span style="color: #EF4444;">*</span></label>
            <select name="kind" required id="draftKind" onchange="toggleDraftFields()" style="width: 100%; height: 38px; padding: 0 10px; border-radius: 6px; border: 1px solid #D1D5DB; font-size: 0.875rem; background: white; box-sizing: border-box;">
              <option value="self">Text post</option>
              <option value="link">Link post</option>
            </select>
          </div>
          <div>
            <label style="font-size: 0.8rem; font-weight: 500; color: #374151; display: block; margin-bottom: 5px;">Title <span style="color: #EF4444;">*</span></label>
            <input type="text" name="title" required placeholder="Post title" maxlength="300" style="width: 100%; height: 38px; padding: 0 12px; border-radius: 6px; border: 1px solid #D1D5DB; font-size: 0.875rem; box-sizing: border-box;">
          </div>
          <div id="bodyField">
            <label style="font-size: 0.8rem; font-weight: 500; color: #374151; display: block; margin-bottom: 5px;">Body</label>
            <textarea name="body" rows="4" placeholder="Post body (Markdown supported)" style="width: 100%; padding: 8px 12px; border-radius: 6px; border: 1px solid #D1D5DB; font-size: 0.875rem; resize: vertical; box-sizing: border-box;"></textarea>
          </div>
          <div id="urlField" style="display: none;">
            <label style="font-size: 0.8rem; font-weight: 500; color: #374151; display: block; margin-bottom: 5px;">URL <span style="color: #EF4444;">*</span></label>
            <input type="url" name="url" placeholder="https://example.com/article" style="width: 100%; height: 38px; padding: 0 12px; border-radius: 6px; border: 1px solid #D1D5DB; font-size: 0.875rem; box-sizing: border-box;">
          </div>
          <div>
            <label style="font-size: 0.8rem; font-weight: 500; color: #374151; display: block; margin-bottom: 5px;">Disclosure <span style="color: #9CA3AF;">(optional)</span></label>
            <input type="text" name="disclosure" placeholder="e.g. I work for this company" style="width: 100%; height: 38px; padding: 0 12px; border-radius: 6px; border: 1px solid #D1D5DB; font-size: 0.875rem; box-sizing: border-box;">
          </div>
          <button type="submit" style="height: 38px; background: #2563EB; color: white; border: none; border-radius: 8px; font-size: 0.875rem; font-weight: 600; cursor: pointer;">Save Draft</button>
        </form>
        <script>
          function toggleDraftFields() {
            const kind = document.getElementById('draftKind').value;
            document.getElementById('bodyField').style.display = kind === 'self' ? '' : 'none';
            document.getElementById('urlField').style.display = kind === 'link' ? '' : 'none';
          }
        </script>
      `}
    </div>
  </div>

</div>
` }) %>
