# Matiks Monitor Configuration

# ============================================
# SEARCH & BRAND CONFIGURATION
# ============================================

# Search terms (comma-separated)
SEARCH_TERMS=matiks,matiks app,matiks.in,matiks math

# Required brand terms (only mentions containing these are stored)
BRAND_REQUIRED_TERMS=matiks.in

# Brand strict mode (default: false). If true, only anchor matches are saved.
BRAND_STRICT=false

# Balanced mode (default: true). If BRAND_STRICT=false, balanced mode keeps only
# "matiks" mentions with app/game/math context.
BRAND_BALANCED=true

# Brand subreddits where ALL posts/comments are saved (comma-separated)
BRAND_SUBREDDITS=matiks

# ============================================
# APP STORE IDs
# ============================================

PLAYSTORE_APP_ID=com.matiks.app
APPSTORE_APP_ID=6738620563





# ============================================
# OPTIONAL: REDDIT OUTREACH (OAuth)
# ============================================
# Create a Reddit app at https://www.reddit.com/prefs/apps (type: web app).
# Set the redirect URI to: http://localhost:3000/outreach/auth/callback
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_REDIRECT_URI=http://localhost:3000/outreach/auth/callback
# REDDIT_USER_AGENT=SocialMonitor/2.0

# ============================================
# OPTIONAL: PROXY CONFIGURATION
# ============================================
# Recommended if you plan to scrape very frequently to avoid IP bans.
# PROXY_HOST=
# PROXY_PORT=
# PROXY_USERNAME=
# PROXY_PASSWORD=

# ============================================
# OPTIONAL: GOOGLE SHEETS EXPORT
# ============================================
# Set to true to verify/enable automatic sync to a sheet
# GOOGLE_SHEETS_ENABLED=false
# GOOGLE_SERVICE_ACCOUNT_JSON=./service-account.json
# GOOGLE_SPREADSHEET_ID=

# ============================================
# SCRAPE INTERVALS (Cron format)
# ============================================

REDDIT_CRON=0 */4 * * *

PLAYSTORE_CRON=0 */3 * * *
APPSTORE_CRON=0 */3 * * *

# ============================================
# BROWSER CONTROLS
# ============================================

# Set HEADLESS=false to see browser during debugging
HEADLESS=true
SLOWMO=0

# ============================================
# SCRAPER TUNING
# ============================================



# ============================================
# SERVER
# ============================================

PORT=3000
LOG_LEVEL=info
