# Social Media Brand Monitor — Configuration Template
# Copy this file to .env and fill in your values.

# ============================================
# BRAND & SEARCH CONFIGURATION
# ============================================

# Keywords to search for on Reddit (comma-separated)
SEARCH_TERMS=yourbrand,yourbrand app,yourbrand.io

# Required terms — at least one must appear in a mention to save it
# (Leave blank to store all results matching SEARCH_TERMS)
REQUIRED_TERMS=yourbrand.io,yourbrand.com

# Strict mode: only keep mentions that contain a REQUIRED_TERMS anchor (default: false)
FILTER_STRICT=false

# Balanced mode: keep mentions only when near app/game/product context words (default: true)
FILTER_BALANCED=true

# Subreddits to crawl entirely — all posts/comments captured regardless of keyword (comma-separated)
MONITOR_SUBREDDITS=yourbrand

# Legacy aliases (also accepted):
# BRAND_REQUIRED_TERMS / BRAND_STRICT / BRAND_BALANCED / BRAND_SUBREDDITS

# ============================================
# APP STORE IDs
# ============================================

# Google Play package name (from the app URL: ?id=com.example.app)
PLAYSTORE_APP_ID=com.example.app

# Apple App Store numeric ID (from the app URL: /id1234567890)
APPSTORE_APP_ID=1234567890

# ============================================
# REDDIT OUTREACH (Optional — OAuth 2.0)
# ============================================
# Create a Reddit app at https://www.reddit.com/prefs/apps
# Type: web app | Redirect URI: http://localhost:3000/outreach/auth/callback

# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_REDIRECT_URI=http://localhost:3000/outreach/auth/callback
# REDDIT_USER_AGENT=SocialMonitor/1.0

# ============================================
# GOOGLE SHEETS EXPORT (Optional)
# ============================================

# GOOGLE_SHEETS_ENABLED=false
# GOOGLE_SERVICE_ACCOUNT_JSON=./service-account.json
# GOOGLE_SPREADSHEET_ID=

# ============================================
# PROXY CONFIGURATION (Optional)
# ============================================
# Recommended for high-frequency scraping to avoid IP bans.

# PROXY_HOST=
# PROXY_PORT=
# PROXY_USERNAME=
# PROXY_PASSWORD=

# ============================================
# SCRAPE SCHEDULES (Cron syntax)
# ============================================

REDDIT_CRON=0 */4 * * *
PLAYSTORE_CRON=0 */3 * * *
APPSTORE_CRON=0 */3 * * *

# ============================================
# BROWSER
# ============================================

# Set HEADLESS=false to watch the browser during debugging
HEADLESS=true
SLOWMO=0

# ============================================
# SERVER
# ============================================

PORT=3000
LOG_LEVEL=info
